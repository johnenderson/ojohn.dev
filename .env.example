# Copie para .env.local e preencha os valores. Nenhuma destas variáveis é
# exposta ao cliente (são usadas apenas no servidor).

# Last.fm — alimenta a página /now e o card de atividade na home.
# Crie a API key em https://www.last.fm/api/account/create
LASTFM_USERNAME=
LASTFM_API_KEY=

# Spotify — usado para buscar capas de faixas/artistas (página /now).
# Crie um app em https://developer.spotify.com/dashboard (Client Credentials).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# GitHub — alimenta o card "Pulso de dev" na home.
# Personal Access Token (classic) com o scope `read:user` já basta para
# contribuições públicas. Sem o token, o card simplesmente não aparece.
GITHUB_TOKEN=
# Opcional: usuário do GitHub (padrão: johnenderson).
# GITHUB_USERNAME=
# Logs de diagnóstico do Pulso de dev (true para ligar).
GITHUB_DEBUG=false
